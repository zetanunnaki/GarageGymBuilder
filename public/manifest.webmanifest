  "description": "Expert reviews, budget builds, and guides to help you build the perfect garage gym. 70+ products tested, 170+ articles.",
  "start_url": "/",
  "id": "/",
  "scope": "/",
  "display": "standalone",
  "display_override": ["window-controls-overlay", "standalone", "minimal-ui"],
  "background_color": "#0a0a0a",
  "theme_color": "#ea580c",
  "orientation": "portrait-primary",
  "lang": "en-US",
  "dir": "ltr",
  "categories": ["fitness", "health", "shopping", "sports"],
  "prefer_related_applications": false,
  "icons": [
    {
      "src": "/icon.svg",
