      "description": "Browse our tested picks for the best home gym equipment",
      "icons": [{ "src": "/icon-192.png", "sizes": "192x192" }]
    },
    {
      "name": "Reviews",
      "short_name": "Reviews",
      "url": "/reviews/",
      "description": "In-depth equipment reviews from people who actually lift",
      "icons": [{ "src": "/icon-192.png", "sizes": "192x192" }]
    },
    {
